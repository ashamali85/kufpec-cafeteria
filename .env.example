# Neon Postgres. Use the POOLED url for DATABASE_URL and the non-pooled url for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/kufpec_cafeteria?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/kufpec_cafeteria?sslmode=require"
APP_URL="http://localhost:3000"
JWT_SECRET="generate-with-openssl-rand-base64-48-min-32-chars"
# Comma-separated list of email domains allowed to self-register.
ALLOWED_EMAIL_DOMAINS="kufpec.com"
